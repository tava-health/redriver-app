# Copy to .env and adjust as needed.

# ----- Server -----
# PORT=1337

# ----- RabbitMQ -----
# AMQP connection URL. The management API URL is derived automatically (same credentials, port 15672).
# Default (local RabbitMQ with default credentials):
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Feather docker (feather/docker):
RABBITMQ_URL=amqp://admin:admin@127.0.0.1:5672
